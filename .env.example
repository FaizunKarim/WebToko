# ===========================================
# Database Configuration (Required)
# ===========================================
# PostgreSQL connection string
# Example: postgresql://username:password@localhost:5432/dbname
DATABASE_URL=

# ===========================================
# Midtrans Payment Gateway (Required)
# ===========================================
# Get your keys from https://dashboard.midtrans.com/
# Server key is used for server-side API calls (creating transactions, checking status)
MIDTRANS_SERVER_KEY=
# Client key is used for server-side Midtrans SDK (generating payment tokens)
MIDTRANS_CLIENT_KEY=
# Public client key is used on the frontend for Midtrans Snap SDK
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=

# ===========================================
# Authentication (Required for auth features)
# ===========================================
# JWT secret key (generate a random string for production)
# Example: openssl rand -base64 32
JWT_SECRET=

# Public app URL
# Example: http://localhost:3000
NEXT_PUBLIC_APP_URL=

# ===========================================
# AI Virtual Try-On (Optional)
# ===========================================
# Replicate API token for AI-powered virtual try-on (IDM-VTON model)
# Without this, the try-on feature falls back to demo mode
# Get from https://replicate.com/
REPLICATE_API_TOKEN=